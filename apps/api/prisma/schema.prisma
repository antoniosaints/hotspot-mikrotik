generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id          String   @id @default(cuid())
  usuario     String   @unique
  senhaHash   String
  role        String   @default("admin")
  nome        String?
  telefone    String?
  email       String?
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Local {
  id          String    @id @default(cuid())
  nome        String
  descricao   String?
  ativo       Boolean   @default(true)
  criadoEm    DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
  hotspots    Hotspot[]
}

model Mikrotik {
  id            String    @id @default(cuid())
  nome          String
  host          String
  usuarioApi    String
  senhaApi      String
  portaApi      Int       @default(8728)
  timeoutApi    Int       @default(5000)
  profilePadrao String
  ativo         Boolean   @default(true)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  hotspots      Hotspot[]
  acessos       Acesso[]
}

model Hotspot {
  id          String     @id @default(cuid())
  nome        String
  slug        String     @unique
  portalUrl   String
  portalLogoUrl String?
  portalTitulo String?
  portalSubtitulo String?
  portalRodape String?
  portalCorFundo String?
  portalCorFundoFim String?
  portalCorTexto String?
  urlPosLogin String?
  loginVoucher Boolean   @default(true)
  loginCpf    Boolean   @default(true)
  loginIntegracao Boolean @default(false)
  integracaoTempoMinutos Int @default(60)
  compraOnline Boolean @default(false)
  compraPersonalizada Boolean @default(false)
  valorMinutoCentavos Int?
  tempoPersonalizadoMinimo Int @default(10)
  tempoPersonalizadoMaximo Int @default(240)
  tempoPersonalizadoPasso Int @default(10)
  conexoesPersonalizado Int @default(1)
  ativo       Boolean    @default(true)
  servidorHotspot String?
  lgpdModo    String     @default("GLOBAL")
  termosUso   String?
  politicaPrivacidade String?
  lgpdConsentimentoTexto String?
  exigirConsentimentoLgpd Boolean?
  localId     String
  mikrotikId  String
  integracaoId String?
  pagamentoIntegracaoId String?
  cadastroTelaId String?
  criadoEm    DateTime   @default(now())
  atualizadoEm DateTime  @updatedAt
  local       Local      @relation(fields: [localId], references: [id], onDelete: Restrict)
  mikrotik    Mikrotik   @relation(fields: [mikrotikId], references: [id], onDelete: Restrict)
  integracao  Integracao? @relation("HotspotLoginIntegracao", fields: [integracaoId], references: [id], onDelete: SetNull)
  pagamentoIntegracao Integracao? @relation("HotspotPagamentoIntegracao", fields: [pagamentoIntegracaoId], references: [id], onDelete: SetNull)
  cadastroTela CadastroTela? @relation(fields: [cadastroTelaId], references: [id], onDelete: SetNull)
  vouchers    Voucher[]
  cpfLogins   CpfLogin[]
  acessos     Acesso[]
  planos      Plano[]
  compras     CompraAcesso[]
  leadsContratacao LeadContratacao[]
  consentimentos ConsentimentoLgpd[]
  campanhas   Campanha[]
  dispositivos Dispositivo[]

  @@unique([mikrotikId, servidorHotspot])
}

// Dispositivo unico por MAC. Consolida os dados coletados em qualquer forma de
// login (cadastro, CPF, IXC, compra) e o historico de conexoes fica no Acesso
// (que ja guarda o mac). Cada nova conexao atualiza os campos disponiveis sem
// apagar os ja preenchidos (ex.: login por voucher so atualiza mac/ultima
// conexao, pois nao coleta dados pessoais).
model Dispositivo {
  id              String    @id @default(cuid())
  mac             String    @unique
  nome            String?
  email           String?
  cpf             String?
  telefone        String?
  whatsapp        String?
  endereco        String?
  cidade          String?
  cep             String?
  aceitouTermos   Boolean   @default(false)
  aceitouTermosEm DateTime?
  ultimoIp        String?
  ultimoTipo      String?
  ultimaConexao   DateTime?
  totalConexoes   Int       @default(0)
  ultimoHotspotId String?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt
  ultimoHotspot   Hotspot?  @relation(fields: [ultimoHotspotId], references: [id], onDelete: SetNull)

  @@index([ultimaConexao])
}

model Configuracao {
  id                     String   @id @default("global")
  termosUso              String   @default("")
  politicaPrivacidade    String   @default("")
  lgpdConsentimentoTexto String   @default("Li e concordo com os Termos de Uso e a Política de Privacidade.")
  lgpdVersao             String   @default("1")
  exigirConsentimento    Boolean  @default(true)
  encarregadoNome        String?
  encarregadoEmail       String?
  empresaNome            String?
  empresaDocumento       String?
  criadoEm               DateTime @default(now())
  atualizadoEm           DateTime @updatedAt
}

model ConsentimentoLgpd {
  id           String   @id @default(cuid())
  hotspotId    String
  versaoTermos String
  ip           String?
  mac          String?
  userAgent    String?
  aceitoEm     DateTime @default(now())
  hotspot      Hotspot  @relation(fields: [hotspotId], references: [id], onDelete: Cascade)

  @@index([hotspotId, aceitoEm])
}

model Campanha {
  id              String   @id @default(cuid())
  nome            String
  tipo            String   @default("IMAGEM")
  momento         String   @default("ANTES_LOGIN")
  ativo           Boolean  @default(true)
  prioridade      Int      @default(0)
  dataInicio      DateTime?
  dataFim         DateTime?
  diasSemana      String   @default("0,1,2,3,4,5,6")
  horaInicio      String?
  horaFim         String?
  exibicao        String   @default("SEMPRE")
  duracaoSegundos Int?
  permitePular    Boolean  @default(true)
  ctaTexto        String?
  ctaUrl          String?
  imagemUrl       String?
  videoUrl        String?
  htmlConteudo    String?
  titulo          String?
  subtitulo       String?
  texto           String?
  corFundo        String?
  corTexto        String?
  blocos          String?
  todosHotspots   Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  hotspots        Hotspot[]
}

model CadastroTela {
  id              String   @id @default(cuid())
  nome            String
  descricao       String?
  coletarNome     Boolean  @default(true)
  coletarEmail    Boolean  @default(false)
  coletarEndereco Boolean  @default(false)
  coletarCidade   Boolean  @default(false)
  coletarCep      Boolean  @default(false)
  coletarTelefone Boolean  @default(false)
  coletarWhatsapp Boolean  @default(false)
  coletarCpf      Boolean  @default(false)
  bonusTempoMinutos Int     @default(0)
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  hotspots        Hotspot[]
  leads           LeadContratacao[]
}

model LeadContratacao {
  id             String   @id @default(cuid())
  nome           String?
  email          String?
  endereco       String?
  cidade         String?
  cep            String?
  telefone       String?
  whatsapp       String?
  cpf            String?
  hotspotId      String
  cadastroTelaId String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  hotspot        Hotspot  @relation(fields: [hotspotId], references: [id], onDelete: Cascade)
  cadastroTela   CadastroTela? @relation(fields: [cadastroTelaId], references: [id], onDelete: SetNull)
}

model Integracao {
  id           String    @id @default(cuid())
  nome         String
  tipo         String    @default("IXC")
  baseUrl      String?
  usuario      String?
  senha        String?
  token        String?
  chaveWebhook String?
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  hotspotsLogin Hotspot[] @relation("HotspotLoginIntegracao")
  hotspotsPagamento Hotspot[] @relation("HotspotPagamentoIntegracao")
  compras      CompraAcesso[]
}

model Plano {
  id                    String   @id @default(cuid())
  nome                  String
  tempoMinutos          Int
  conexoesSimultaneas   Int      @default(1)
  valorCentavos         Int
  ativo                 Boolean  @default(true)
  coletarNome           Boolean  @default(false)
  coletarTelefone       Boolean  @default(false)
  coletarEmail          Boolean  @default(false)
  coletarCpf            Boolean  @default(false)
  coletarEndereco       Boolean  @default(false)
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt
  hotspots              Hotspot[]
  compras               CompraAcesso[]

  @@map("PlanoBilheteria")
}

model CompraAcesso {
  id                    String    @id @default(cuid())
  status                String    @default("PENDENTE")
  valorCentavos         Int
  tempoMinutos          Int?
  mercadoPagoPaymentId  String?
  mercadoPagoStatus     String?
  loginUsuario          String?
  loginSenha            String?
  nome                  String?
  telefone              String?
  email                 String?
  cpf                   String?
  endereco              String?
  mac                   String?
  ip                    String?
  pagoEm                DateTime?
  liberadoEm            DateTime?
  erroLiberacao         String?
  janelaExpiraEm        DateTime?
  tempoExpiraEm         DateTime?
  ultimaVerificacaoEm   DateTime?
  hotspotId             String
  planoId               String?
  pagamentoIntegracaoId String?
  acessoId              String?   @unique
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt
  hotspot               Hotspot   @relation(fields: [hotspotId], references: [id], onDelete: Cascade)
  plano                 Plano?    @relation(fields: [planoId], references: [id], onDelete: Restrict)
  pagamentoIntegracao   Integracao? @relation(fields: [pagamentoIntegracaoId], references: [id], onDelete: SetNull)
  acesso                Acesso?   @relation(fields: [acessoId], references: [id], onDelete: SetNull)

  @@unique([mercadoPagoPaymentId])
}

model Voucher {
  id           String    @id @default(cuid())
  codigo       String    @unique
  tempoMinutos Int
  usado        Boolean   @default(false)
  vendido      Boolean   @default(false)
  vendidoEm    DateTime?
  segmentacao  String?
  mac          String?
  ip           String?
  usadoEm      DateTime?
  hotspotId    String
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  hotspot      Hotspot   @relation(fields: [hotspotId], references: [id], onDelete: Cascade)
  acessos      Acesso[]
}

model CpfLogin {
  id           String    @id @default(cuid())
  nome         String
  cpf          String
  telefone     String?
  tempoMinutos Int
  ativo        Boolean   @default(true)
  usadoEm      DateTime?
  hotspotId    String
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  hotspot      Hotspot   @relation(fields: [hotspotId], references: [id], onDelete: Cascade)
  acessos      Acesso[]

  @@unique([hotspotId, cpf])
}

model Acesso {
  id           String    @id @default(cuid())
  tipo         String
  codigo       String
  mac          String?
  ip           String?
  loginEm      DateTime  @default(now())
  expiraEm     DateTime
  status       String    @default("LIBERADO")
  hotspotId    String
  mikrotikId   String?
  voucherId    String?
  cpfLoginId   String?
  compra       CompraAcesso?
  hotspot      Hotspot   @relation(fields: [hotspotId], references: [id], onDelete: Cascade)
  mikrotik     Mikrotik? @relation(fields: [mikrotikId], references: [id], onDelete: SetNull)
  voucher      Voucher?  @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  cpfLogin     CpfLogin? @relation(fields: [cpfLoginId], references: [id], onDelete: SetNull)
}
